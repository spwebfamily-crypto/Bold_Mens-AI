{
  "name": "boldmens-whatsapp-ai",
  "version": "1.0.0",
  "description": "WhatsApp AI assistant for Bold Men's Salon",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest --pool threads --poolOptions.threads.singleThread --dir tests",
    "test:run": "vitest run --pool threads --poolOptions.threads.singleThread --dir tests"
  },
  "keywords": [
    "whatsapp",
    "twilio",
    "openai",
    "express",
    "mongodb",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cloudinary": "^2.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "mongoose": "^8.13.2",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.3.0",
    "twilio": "^5.5.2",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
