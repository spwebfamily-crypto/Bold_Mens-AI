# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
ALLOW_MOCK_ANALYSIS=false

# Anthropic legacy fallback (not used by the current backend)
ANTHROPIC_API_KEY=sk-ant-...

# MongoDB
MONGODB_URI=mongodb+srv://boldmens:...@cluster0.mongodb.net/boldmens

# Redis
REDIS_URL=redis://...

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=dcswmesvt
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# RevenueCat
REVENUECAT_API_KEY=...
REVENUECAT_WEBHOOK_AUTH=...

# iOS / App Store
IOS_BUNDLE_IDENTIFIER=co.boldmens.ai

# App
PORT=3000
NODE_ENV=development
BOLDMENS_WEBSITE=https://boldmens.co
API_BASE_URL=http://localhost:3000
CORS_ORIGINS=https://boldmens.co,http://localhost:8081
FREE_DAILY_LIMIT=3

# Expo public env
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_FREE_DAILY_LIMIT=3
